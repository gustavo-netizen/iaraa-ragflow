# DocMind 0.8 Environment Configuration
# Copy this file to .env and fill in your API keys

# Aliyun DashScope API Keys (Qwen-VL)
# Get your key at: https://dashscope.console.aliyun.com/
# Support up to 8 keys for load balancing

DASHSCOPE_API_KEY_1=your-api-key-1-here
DASHSCOPE_API_KEY_2=your-api-key-2-here
DASHSCOPE_API_KEY_3=your-api-key-3-here
DASHSCOPE_API_KEY_4=your-api-key-4-here
DASHSCOPE_API_KEY_5=your-api-key-5-here
DASHSCOPE_API_KEY_6=your-api-key-6-here
DASHSCOPE_API_KEY_7=your-api-key-7-here
DASHSCOPE_API_KEY_8=your-api-key-8-here

# Or use a single key (fallback)
# DASHSCOPE_API_KEY=your-api-key-here

# OpenAI API Key (Optional)
# Only required if using scripts/admin/recover_moderation_blocked.py to re-process pages blocked by Qwen content moderation
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Processing settings (Optimized for 6 API keys)
# MAX_PAGES=50       # Max pages per chunk (default: 50)
# MAX_SIZE=50        # Max MB per chunk (default: 50)
# SEMAPHORE=30       # Concurrent PDF processing (default: 30, optimized for 6 keys)
# LLM_CONCURRENT=10  # LLM calls per PDF (default: 10, optimized for 6 keys)
# Total concurrent: 30 × 10 = 300 API calls, ~50 per key, 11.1 RPS, 8.9 RPS headroom
